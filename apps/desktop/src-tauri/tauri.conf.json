{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orbit",
  "version": "0.1.0",
  "identifier": "app.orbit.desktop",
  "build": {
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "Orbit",
        "width": 1200,
        "height": 800,
        "minWidth": 380,
        "minHeight": 640,
        "backgroundColor": "#06070a",
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
